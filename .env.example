# Copy this file to .env and fill in the values.

# BUas Ollama server (needs the BUas network or VPN).
# Example: http://<server-ip>:<port>
OLLAMA_HOST=http://<BUAS_OLLAMA_HOST>:<PORT>

# Green-API credentials for the WhatsApp bot.
# Find these in your Green-API instance dashboard.
GREEN_API_HOST=https://<HOST>.api.greenapi.com
GREEN_API_ID_INSTANCE=<ID_INSTANCE>
GREEN_API_TOKEN_INSTANCE=<API_TOKEN_INSTANCE>
